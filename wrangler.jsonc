{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cgchecklist",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "build": {
    "command": "npx opennextjs-cloudflare build"
  },
  "observability": {
    "enabled": true
  }
}
